# ─────────────────────────────────────────────────────────────────────────
# Formulasyon — ortam değişkenleri ŞABLONU
# Kullanım: bu dosyayı `.env.local` olarak kopyala ve değerleri doldur.
#   cp .env.example .env.local
# NOT: Gerçek `.env.local` ve `data.db` gizlilik gereği repoya GİRMEZ
# (gizli anahtarlar + danışan PII'si). Bu dosya yalnızca hangi değişkenlerin
# gerektiğini gösterir.
# ─────────────────────────────────────────────────────────────────────────

# Site adresi (geliştirmede localhost yeterli)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Oturum / giriş (prototip: giriş kapısı kapalı)
# AUTH_SECRET için rastgele uzun bir dize üret:  openssl rand -base64 32
AUTH_SECRET=
AUTH_PASSWORDLESS=1

# Netgsm SMS — Profil → Bildirim & SMS'ten alınır (opsiyonel; SMS göndermek için)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=

# Google OAuth (opsiyonel — Google ile giriş için)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (opsiyonel — Microsoft ile giriş için)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Resend e-posta (opsiyonel — e-posta göndermek için)
RESEND_API_KEY=
MAIL_FROM=
